# Copy to `.env` for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Required in production: your API base URL (include trailing path segment your backend expects, e.g. /api/)
VITE_API_BASE_URL=https://api.spacehaat.com/api/

# Optional: local override (used when VITE_API_BASE_URL is unset)
# VITE_API_BASE_URL_LOCAL=http://localhost:8000/api/

# Optional: public marketing site for “Preview” in admin
# Coworking (India / default): {VITE_WEBSITE_URL}/coworking/{slug} e.g. https://spacehaat.com/coworking/awfis-ambience-mall
VITE_WEBSITE_URL=https://spacehaat.com
# Multi-country coworking preview (non-India): {VITE_WEBSITE_URL_COUNTRY}/{country}/coworking-details/{slug}
# VITE_WEBSITE_URL_COUNTRY=https://your-site.com
# Office listing preview base:
# VITE_OFFICE_URL=https://your-site.com/office-space/rent/
